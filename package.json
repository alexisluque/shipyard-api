{
  "name": "shipyard",
  "version": "1.0.0",
  "description": "Backend API for Shipyard, a production-like full-stack platform focused on DevOps practices.",
  "type": "module",
  "main": "index.ts",
  "scripts": {
    "start": "node dist/src/index.js",
    "dev:start": "tsx src/index.ts",
    "dev:watch": "tsx watch src/index.ts",
    "compile": "tsc",
    "type-check": "tsc --noEmit",
    "lint": "eslint ./src",
    "lint:fix": "eslint --fix ./src",
    "format": "prettier --write ./src",
    "format:check": "prettier --check ./src",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "keywords": [
    "nodejs",
    "express",
    "postgresql",
    "docker",
    "docker-compose",
    "nginx",
    "devops",
    "ci-cd",
    "aws",
    "terraform",
    "full-stack",
    "microservices",
    "rest-api"
  ],
  "author": "Alexis Luque",
  "license": "MIT",
  "packageManager": "pnpm@10.29.2",
  "dependencies": {
    "dotenv": "^17.4.1",
    "express": "^5.2.1",
    "pg": "^8.20.0"
  },
  "devDependencies": {
    "@eslint/css": "^1.1.0",
    "@eslint/js": "^10.0.1",
    "@eslint/json": "^1.2.0",
    "@eslint/markdown": "^8.0.1",
    "@tsconfig/node24": "^24.0.4",
    "@types/express": "^5.0.6",
    "@types/node": "^25.5.2",
    "@types/pg": "^8.20.0",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.4.0",
    "jiti": "^2.6.1",
    "prettier": "^3.8.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.0"
  }
}
