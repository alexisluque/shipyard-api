{
  "name": "shipyard",
  "version": "1.0.0",
  "description": "Backend API for Shipyard, a production-like full-stack platform focused on DevOps practices.",
  "type": "module",
  "main": "index.ts",
  "scripts": {
    "start": "node dist/src/index.js",
    "dev:start": "tsx src/index.ts",
    "dev:db:up": "docker compose up db -d",
    "dev:db:down": "docker compose down",
    "dev:watch": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.build.json",
    "type-check": "tsc --noEmit",
    "lint": "eslint ./src",
    "lint:fix": "eslint --fix ./src",
    "format": "prettier --write ./src",
    "format:check": "prettier --check ./src",
    "test": "vitest",
    "test:ci": "vitest run",
    "test:db:up": "docker compose -f docker-compose.test.yml up -d",
    "test:db:down": "docker compose -f docker-compose.test.yml down",
    "prepare": "husky"
  },
  "keywords": [
    "nodejs",
    "express",
    "postgresql",
    "docker",
    "docker-compose",
    "nginx",
    "devops",
    "ci-cd",
    "aws",
    "terraform",
    "full-stack",
    "microservices",
    "rest-api"
  ],
  "author": "Alexis Luque",
  "license": "MIT",
  "packageManager": "pnpm@10.33.0",
  "dependencies": {
    "bcrypt": "^6.0.0",
    "dotenv": "^17.4.1",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "pg": "^8.20.0",
    "supertest": "^7.2.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/css": "^1.1.0",
    "@eslint/js": "^10.0.1",
    "@eslint/json": "^1.2.0",
    "@eslint/markdown": "^8.0.1",
    "@tsconfig/node24": "^24.0.4",
    "@types/bcrypt": "^6.0.0",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.5.2",
    "@types/pg": "^8.20.0",
    "@types/supertest": "^7.2.0",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.4.0",
    "husky": "^9.1.7",
    "jiti": "^2.6.1",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.0",
    "vitest": "^4.1.4"
  },
  "lint-staged": {
    "**/*": [
      "eslint --fix ./src",
      "prettier --write --ignore-unknown"
    ]
  }
}
